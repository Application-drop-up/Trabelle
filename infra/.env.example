DB_USER=postgres
DB_PASSWORD=password
DB_NAME=travellle

# Comma-separated list of origins allowed to call the API cross-origin.
# Defaults to http://localhost:3000,http://localhost:3001 if unset.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Local/dev: any non-empty placeholder works (e.g. "dummy") since Spot search calls will fail anyway.
# Production: set a real Google Places API key here (billing applies).
GOOGLE_PLACES_API_KEY=dummy
